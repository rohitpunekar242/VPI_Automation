{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "noEmit": true
  },
  "include": ["playwright.config.ts", "fixtures/**/*.ts", "pages/**/*.ts", "tests/**/*.ts"]
}
